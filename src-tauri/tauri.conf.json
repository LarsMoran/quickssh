{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "quickssh",
	"version": "0.2.0",
	"identifier": "com.quickssh.app",
	"build": {
		"beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420 --strictPort",
		"beforeBuildCommand": "npm run build",
		"devUrl": "http://127.0.0.1:1420/",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "quickssh",
				"width": 1280,
				"height": 800,
				"minWidth": 960,
				"minHeight": 640,
				"resizable": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["deb", "appimage"],
		"icon": ["icons/icon.png"]
	}
}
